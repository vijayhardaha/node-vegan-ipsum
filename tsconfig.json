// ==============================================================================
// TSCONFIG — TypeScript Compiler Options
// ==============================================================================
// Purpose: Configure TypeScript for strict type-checking and declaration output.
// Docs: https://www.typescriptlang.org/tsconfig
// ==============================================================================

{
    // ==========================================
    // TRANSPILE & MODULE TARGETS
    // ==========================================
    // Target modern JS runtime features; module is ESM to align with Vite outputs.
    "compilerOptions": {
        "target": "esnext",
        "module": "esnext",

        // ==========================================
        // TYPE OUTPUT
        // ==========================================
        // Emit declaration files into `types/` for consumers.
        "declaration": true,
        "declarationDir": "types",

        // ==========================================
        // STRICTNESS & RESOLUTION
        // ==========================================
        // Enforce strict checks and enable convenient JSON imports.
        "strict": true,
        "esModuleInterop": true,
        "moduleResolution": "bundler"
    },

    // ==========================================
    // SCOPE
    // ==========================================
    // Include source + test helpers; exclude build artifacts and test files that
    // should not be compiled directly by the type checker.
    "include": ["src/**/*.ts", "tests/**/*.ts", "./*.config.ts"],
    "exclude": ["node_modules", "**/*.test.ts"]
}
