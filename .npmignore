# ==============================================================================
# NPMIGNORE — Files excluded from published package
# ==============================================================================
# Purpose: Controls package contents uploaded to npm to keep tarball minimal.
# Docs: https://docs.npmjs.com/cli/v9/configuring-npm/package-json#files
# ==============================================================================

# ==========================================
# Development / Local
# ==========================================
/node_modules
/.vscode
/.husky
/.github
/.git

# ==========================================
# Testing & Reports
# ==========================================
/coverage
/test
/tests

# ==========================================
# Project Configs (kept locally but not published)
# ==========================================
.babelrc
.editorconfig
.prettierignore
.prettierrc
.nvmrc
eslint.config.mjs
tsconfig.json
.release-it.json
commitlint.config.mjs
prettier.config.mjs
vite.config.ts
vitebin.config.ts
vitest.config.ts

# ==========================================
# Build artifacts
# ==========================================
# NOTE: `dist/` is intentionally commented out to include builds in the package.
# Uncomment if you prefer to publish source-only and build in CI/publish pipeline.
#/dist

# ==========================================
# Misc
# ==========================================
.DS_Store
.Thumbnails
*.zip
*.tgz
*.tsbuildinfo

# ==========================================
# Logs
# ==========================================
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ==========================================
# Environment Variables
# ==========================================
.env
.env.local
