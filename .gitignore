# ==============================================================================
# GITIGNORE — Files and directories ignored by Git
# ==============================================================================
# Purpose: Prevents committing generated files, local IDE settings, and secrets.
# Docs: https://git-scm.com/docs/gitignore
# ==============================================================================

# ==========================================
# IDE & Editor
# ==========================================
.idea/
.vscode/

# ==========================================
# Dependencies & Build
# ==========================================
/node_modules
/dist
/types

# ==========================================
# Testing & Coverage
# ==========================================
/coverage

# ==========================================
# Misc & OS
# ==========================================
.DS_Store
.Thumbnails

# ==========================================
# Logs & Temporary
# ==========================================
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ==========================================
# Typescript Cache
# ==========================================
*.tsbuildinfo

# ==========================================
# Environment
# ==========================================
.env
.env.local
